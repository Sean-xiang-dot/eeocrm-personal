# 销售易 OAuth2 应用凭证（必填）
XIAOSHOUYI_CLIENT_ID=your_client_id
XIAOSHOUYI_CLIENT_SECRET=your_client_secret

# 环境: sandbox | production
XIAOSHOUYI_ENV=sandbox

# 销售易 API 地址（测试环境用 sandbox，生产环境替换为正式地址）
XIAOSHOUYI_BASE_URL=https://api-sandbox.xiaoshouyi.com

# 注：不再支持默认账户配置，请通过 MCP 的 crm_login 工具使用自己的账户登录

# MCP Server 端口
PORT=3000

# 可选：限制允许访问的来源 Token（用于简单鉴权）
MCP_AUTH_TOKEN=your_secret_token_here

# ========== 提醒系统（可选） ==========
# 默认提醒回调地址（订阅未单独配置时使用）
REMINDER_WEBHOOK_URL=

# 调度扫描间隔（分钟）
REMINDER_INTERVAL_MINUTES=10

# 幂等去重窗口（小时）
REMINDER_DEDUPE_HOURS=24

# 订阅与去重存储文件（默认落到 ./data）
# REMINDER_STORE_FILE=./data/reminder-subscriptions.json
# REMINDER_DEDUPE_FILE=./data/reminder-dedupe.json
